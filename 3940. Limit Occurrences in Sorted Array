// Contest LC
using ll   =  long long;
using vi  =  vector<int>;
using vll  =  vector<ll>;
#define pb push_back
#define sorta(v) sort((v).begin(), (v).end())
#define foo(i, a, b) for (int i = (a); i < (b); ++i )


class Solution {
public:
    vector<int> limitOccurrences(vector<int>& n, int k) {
        ll w=0;
        foo(i,0,n.size()){
            if(w<k || n[i] != n[w-k]) n[w++] = n[i] ;
        }
        n.resize(w);
        return n ;
    }
};
