// Contest LC
using ll   =  long long;
using vi  =  vector<int>;
using vll  =  vector<ll>;
#define pb push_back
#define sorta(v) sort((v).begin(), (v).end())
#define foo(i, a, b) for (int i = (a); i < (b); ++i )


class Solution {
public:
    vector<int> pivotArray(vector<int>& n, int pv) {
        vi ans ;
        for(auto x : n)
        {
            if(x < pv) ans.pb(x);
        }
        for(auto x : n)
        {
            if(x == pv)ans.pb(x);
        }
        for(auto x : n)
        {
            if(x >pv) ans.pb(x);
        }
        return ans;
    }
};
