using ll   =  long long;
using vi  =  vector<int>;
using vll  =  vector<ll>;
#define pb push_back
#define sorta(v) sort((v).begin(), (v).end())
#define foo(i, a, b) for (int i = (a); i < (b); ++i )


class Solution {
public:
    vector<int> arrayRankTransform(vector<int>& a) {
        vi t;
        t=a;
        sort(t.begin(),t.end());
        map<int,int>p;
        int rank=1;
        for(int i=0;i<t.size();i++)
        {
            if(p.find(t[i])==p.end())
            {
                p[t[i]]=rank;
                rank++;
            }
        }
        for(int i=0;i<a.size();i++){
            t[i]=p[a[i]];
        }
        return t;
    }
};
