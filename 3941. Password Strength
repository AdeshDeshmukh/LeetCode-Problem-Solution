class Solution {
public:
    int passwordStrength(string p) {
        unordered_set<char> s(p.begin(), p.end()) ;
        ll re=0;
        for(auto c:s){
            if(c >='a' && c<='z') re+=1 ;
            else if(c>= 'A' && c<= 'Z') re +=2 ;
            else if(c>= '0' && c<= '9') re +=3 ;
            else re += 5 ;
        }return re ;
        
    }
};
