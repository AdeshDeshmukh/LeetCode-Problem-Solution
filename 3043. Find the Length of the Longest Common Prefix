using ll   =  long long;
using vi  =  vector<int>;
using vll  =  vector<ll>;
#define pb push_back
#define sorta(v) sort((v).begin(), (v).end())
#define foo(i, a, b) for (int i = (a); i < (b); ++i )


class Solution {
public:
    int longestCommonPrefix(vector<int>& a1, vector<int>& a2) {
        unordered_set<int> p;
        for (int n : a1) {
            while (n > 0) {
                p.insert(n);
                n /= 10;
            }
        }

        int ml = 0;
        for (int n : a2) {
            while (n > 0) {
                if (p.count(n)) {
                    int cl = to_string(n).length();
                    ml = max(ml, cl);
                    
                    break; 
                }
                n /= 10;
            }
        }

        return ml;
    }
};
