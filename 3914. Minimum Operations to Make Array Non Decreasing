// Contest LC
using ll   =  long long;
using vi  =  vector<int>;
using vll  =  vector<ll>;
#define pb push_back
#define sorta(v) sort((v).begin(), (v).end())
#define foo(i, a, b) for (int i = (a); i < (b); ++i )


class Solution {
public:
    long long minOperations(vector<int>& n) {
        ll c= 0 , mf = n[0] , p= 0;
        foo(i,1,n.size()){
            ll ci = max(mf - n[i] , 0LL);
            c+= max(ci -p, 0LL);
            p = ci ;
            mf = max(mf , (ll)n[i]) ;
        }
        return c;
    }
};
