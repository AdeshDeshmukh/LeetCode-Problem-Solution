class Solution {
public:
    ListNode* addTwoNumbers(ListNode* l1, ListNode* l2) {
        ListNode* d = new ListNode(0);
        ListNode* c = d;

        int carry=0;
        while(l1||l2||carry){
            int x = l1?l1->val:0;
            int y = l2?l2->val:0;
            int s = x+y+carry;
            if(l1) l1=l1->next;
            if(l2) l2=l2->next;
            carry = s/10;
            c->next = new ListNode(s%10);
            c = c->next;
        }
        return d->next;
    }
};
