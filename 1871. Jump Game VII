// Contest LC
using ll   =  long long;
using vi  =  vector<int>;
using vll  =  vector<ll>;
#define pb push_back
#define sorta(v) sort((v).begin(), (v).end())
#define foo(i, a, b) for (int i = (a); i < (b); ++i )


class Solution {
public:
    bool canReach(string s, int mj, int mxj) {
        int n = s.size();
        if(s.back() == '1')
            return false;
        vector<int> d(n + 1);
        d[mj]++;
        d[min(mxj + 1, n)]--;
        int sum = 0;
        for(int i = 1;i < n;i++){
            sum += d[i];
            if(s[i] == '0' and sum > 0){
                if(i == n - 1)
                    return true;
                d[min(i + mj, n)]++;
                d[min(i + mxj + 1, n)]--;
            }
        }
        return false;
    }
};
