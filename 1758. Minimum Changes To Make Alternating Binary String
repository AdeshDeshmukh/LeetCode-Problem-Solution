// Contest LC
using ll   =  long long;
using vi  =  vector<int>;
using vll  =  vector<ll>;
#define pb push_back
#define sorta(v) sort((v).begin(), (v).end())
#define foo(i, a, b) for (int i = (a); i < (b); ++i )


class Solution {
public:
    int minOperations(string s) {
        ll c1 = 0 , c2 = 0;
        ll p1 = '0', p2 = '1';
        foo(i,0,s.size()){
            if(s[i] != p1)c1 ++;
            if(s[i] != p2)c2 ++;
            char c = p1;
            p1 = p2;
            p2 = c;
        }
        return min(c1,c2);
    }
};
