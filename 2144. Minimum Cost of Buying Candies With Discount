// Contest LC
using ll   =  long long;
using vi  =  vector<int>;
using vll  =  vector<ll>;
#define pb push_back
#define sorta(v) sort((v).begin(), (v).end())
#define foo(i, a, b) for (int i = (a); i < (b); ++i )


class Solution {
public:
    int minimumCost(vector<int>& c) 
    {
        sort(c.begin(),c.end());
        int re = 0;
        int ct = 0;
        for(int i=c.size()-1;i>=0;i--)
        {
            ct++;
            if(ct%3==0) continue;
            re += c[i];
        }
        return re;
    }
};
