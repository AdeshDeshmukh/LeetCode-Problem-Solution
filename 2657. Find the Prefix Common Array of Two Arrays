using ll   =  long long;
using vi  =  vector<int>;
using vll  =  vector<ll>;
#define pb push_back
#define sorta(v) sort((v).begin(), (v).end())
#define foo(i, a, b) for (int i = (a); i < (b); ++i )


class Solution {
public:
    vector<int> findThePrefixCommonArray(vector<int>& A, vector<int>& B) {
        unordered_set<int>s;
        vi ans;
        for(int i = 0 ; i < A.size();i++){
            s.insert(A[i]);
            s.insert(B[i]);
            int sz = s.size();
            ans.pb(((i+1)*2)-sz);
        }
        return ans;
    }
};
