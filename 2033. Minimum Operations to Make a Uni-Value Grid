// Contest LC
using ll   =  long long;
using vi  =  vector<int>;
using vll  =  vector<ll>;
#define pb push_back
#define sorta(v) sort((v).begin(), (v).end())
#define foo(i, a, b) for (int i = (a); i < (b); ++i )


class Solution {
    public:
        int minOperations(vector<vector<int>>& g, int x) {
            vi n;
            for (auto &row : g) {
                for (int k : row) {
                    n.pb(k);
                }
            }
            sorta(n); 
            int tg = n[n.size() / 2];
            ll to = 0;
            for (int k : n) {
                int t = abs(k - tg);
                if (t % x != 0) return -1;
                to += t / x; 
            }
            return to;
        }
    };
