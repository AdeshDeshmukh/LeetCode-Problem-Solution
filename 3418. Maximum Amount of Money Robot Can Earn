// Contest LC
using ll   =  long long;
using vi  =  vector<int>;
using vll  =  vector<ll>;
#define pb push_back
#define sorta(v) sort((v).begin(), (v).end())
#define foo(i, a, b) for (int i = (a); i < (b); ++i )


class Solution {
public:
    int maximumAmount(vector<vector<int>>& co) {
        ll n = co.size(), m = co[0].size();
        vector d(n, vector(m, vi(3, -1e9)));
        d[0][0][1] = d[0][0][2] = 0, d[0][0][0] = co[0][0];
        
        foo(i,0,n)
            foo(j,0,m)
                foo(k,0,3) {
                    if (i) d[i][j][k] = max(d[i][j][k], d[i - 1][j][k] + co[i][j]);
                    if (i && k) d[i][j][k] = max(d[i][j][k], d[i - 1][j][k - 1]);
                    if (j) d[i][j][k] = max(d[i][j][k], d[i][j - 1][k] + co[i][j]);
                    if (j && k) d[i][j][k] = max(d[i][j][k], d[i][j - 1][k - 1]);
                }
        int ans = *max_element(d[n - 1][m - 1].begin(), d[n - 1][m - 1].end());
        return ans;
    }
};
