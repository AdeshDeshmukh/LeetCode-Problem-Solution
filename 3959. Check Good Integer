using ll   =  long long;
using vi  =  vector<int>;
using vll  =  vector<ll>;
#define pb push_back
#define sorta(v) sort((v).begin(), (v).end())
#define foo(i, a, b) for (int i = (a); i < (b); ++i )


class Solution {
public:
    bool checkGoodInteger(int n) {

        ll diff=0 ;
        while(n>0){
            ll d=n%10;
            diff += d*(d-1);
            if(diff>=50) return true ;
            n/=10;
        } return diff>=50 ;
    }
};
