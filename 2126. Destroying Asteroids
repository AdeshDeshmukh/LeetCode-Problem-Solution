// Contest LC
using ll   =  long long;
using vi  =  vector<int>;
using vll  =  vector<ll>;
#define pb push_back
#define sorta(v) sort((v).begin(), (v).end())
#define foo(i, a, b) for (int i = (a); i < (b); ++i )


class Solution {
public:
    bool asteroidsDestroyed(int ma, vector<int>& a) {
        sorta(a);
        long long m = ma;
        for(int i=0;i<a.size();i++){
            if(m<a[i]) return false;
            m += a[i];
        }
        return true;
    }
};
