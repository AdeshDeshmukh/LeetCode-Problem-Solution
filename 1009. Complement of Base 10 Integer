class Solution {
public:
    int bitwiseComplement(int n) {
        if(n==0) return 1;
        int bm = 0 , t = n;
        while(t){
            bm<<=1;
            bm |= 1; 
            t>>=1;
        }
        return bm ^ n;
        
    }
};
