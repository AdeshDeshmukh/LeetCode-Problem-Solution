// Contest LC
using ll   =  long long;
using vi  =  vector<int>;
using vll  =  vector<ll>;
#define pb push_back
#define sorta(v) sort((v).begin(), (v).end())
#define foo(i, a, b) for (int i = (a); i < (b); ++i )


class Solution {
public:
    long long minNumberOfSeconds(int m, vector<int>& a) {
        ll n = a.size();
        auto check = [&](ll mid) {
            ll res = 0;
            foo(i,0,n) {
                ll s = 0, e = 1e6, mm, an = 0;
                while(s <= e) {
                    mm = s + (e - s)/2;
                    if(mm*(mm + 1)/2 * a[i] <= mid) {
                        an = mm;
                        s = mm + 1;
                    } else {
                        e = mm - 1;
                    }
                }
                res += an;
            }return res >= m;
        };

        ll s = 0, e = 1e18, mid, ans;
        while(s <= e) {
            mid = s + (e - s)/2;
            if(check(mid)) {
                ans = mid;
                e = mid - 1;
            } else {
                s = mid + 1;
            }
        }return ans;
    }
};
