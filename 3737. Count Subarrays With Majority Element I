#include <bits/stdc++.h>
using namespace std;

#define foo(i, a, b) for (int i = (a); i < (b); ++i)
#define foop(j, c, d) for (int j = (c); j <= (d); ++j)
#define rfoop(i, a, b) for (int i = (a) - 1; i >= (b); --i)
#define all(x) (x).begin(), (x).end()
#define sz(x) ((int)(x).size())
#define pb push_back
#define ppb pop_back

using ll   =  long long;
using vll  =  vector<ll>;
using pll  =  pair<ll, ll>;
using vpll =  vector<pll>;
using vi   =  vector<int>;
using pi   =  pair<int, int>;
using vpi  =  vector<pi>;
using mii  =  unordered_map<int,int>;
using mll  =  unordered_map<ll,ll>;

#define sorta(v) sort(all(v))
#define sortd(v) sort(all(v), greater<>()) // C++14+
#define reverse(v) reverse(all(v))

class Solution {
public:
    int countMajoritySubarrays(vector<int>& n, int t) {
        ll d = sz(n);
        ll sub = 0;
        
        foo(i, 0, d) {
            ll tc = 0;
            foo(j, i, d) {
                if (n[j] == t) tc++;
                ll len = j - i + 1;
                if (tc * 2 > len) sub++;
            }
        }return sub;
    }
};
