using ll   =  long long;
using vi  =  vector<int>;
using vll  =  vector<ll>;
#define pb push_back
#define sorta(v) sort((v).begin(), (v).end())
#define foo(i, a, b) for (int i = (a); i < (b); ++i )


class Solution {
public:
    bool checkStrings(string s1, string s2) {
        unordered_map<int, int> a1,b1,a2,b2;
        for(int i = 0; i < s1.size(); i++) {
            if(i&1){
                a1[s1[i]]++;
                a2[s2[i]]++;
            } else{
                b1[s1[i]]++;
                b2[s2[i]]++;
            }
        }

        return (a1 == a2 && b1 == b2) ;
    }
};
