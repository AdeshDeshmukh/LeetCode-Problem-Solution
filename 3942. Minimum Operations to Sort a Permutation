// Contest LC
using ll   =  long long;
using vi  =  vector<int>;
using vll  =  vector<ll>;
#define pb push_back
#define sorta(v) sort((v).begin(), (v).end())
#define foo(i, a, b) for (int i = (a); i < (b); ++i )


class Solution {
public:
    int minOperations(vector<int>& n) {
        ll sz = n.size() ;
        if(sz == 1) return 0;
        bool i1 = true , i2 = true ;
        ll a= 0;
        foo(i,0,sz){
            if(n[i] == 0) a = i;
            if(n[(i+1)%sz] != (n[i]+1) % sz )  i1=false ;
            if(n[(i+1)%sz] != (n[i] -1 +sz) %sz  ) i2=false ;
            
        }
        if(!i1 && !i2) return -1 ;
        ll re= 50000000 ;
        if(i1) {
            if(a==0) re=0 ;
            else re = min({re , a , sz- a+2} );
            
        }
        if(i2) re= min({re , sz-a ,((a+1)%sz)+1} ) ;

            return re ;
    }
};
