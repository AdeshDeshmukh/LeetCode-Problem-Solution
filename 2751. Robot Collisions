// Contest LC
using ll   =  long long;
using vi  =  vector<int>;
using vll  =  vector<ll>;
#define pb push_back
#define sorta(v) sort((v).begin(), (v).end())
#define foo(i, a, b) for (int i = (a); i < (b); ++i )


class Solution {
public:
    vector<int> survivedRobotsHealths(vector<int>& ps, vector<int>& h, string d) {
        int n = ps.size();
        vi index(n);
        foo(i,0,n)index[i] = i;
        sort(index.begin(), index.end(), [&ps](int a, int b){
            return ps[a] < ps[b];
        });
        vi st;
        for (int i : index){
            if (d[i] == 'R'){
                st.pb(i);
                continue;
            }
            while (!st.empty() && h[i] > 0){
                if (h[st.back()] < h[i]){
                    h[st.back()] = 0;
                    st.pop_back();
                    h[i] -= 1;
                } else if (h[st.back()] > h[i]) {
                    h[st.back()] -= 1;
                    h[i] = 0;
                } else {
                    h[st.back()] = 0;
                    h[i] = 0;
                    st.pop_back();
                }
            }
        }
        vi re;
        for (int h : h) {
            if (h > 0) {
                re.pb(h);
            }
        }

        return re;
    }
};
